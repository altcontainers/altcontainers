    "enableSessionKnowledge": true,
    "enableInspectionCache": true,
    "maxKnowledgeFiles": 192,
    "maxKnowledgeValidations": 96,
    "maxKnowledgeUnresolved": 48,
    "maxKnowledgeCheckpoints": 48,
    "tokenEstimator": "calibrated",
    "maxScannedFiles": 20000
  },
  "agentTimeoutSeconds": 900,
  "toolTimeoutSeconds": 600
