{
  "provider": "deepseek",
  "model": "deepseek-v4-flash",
  "tools": [
    "read",
    "bash",
    "grep",
    "rg",
    "find",
    "ls",
    "write"
  ],
  "workingDirectory": "/home/dhoard/Development/github/altcontainers/altcontainers",
  "contextManagement": {
    "contextWindowTokens": 1000000,
    "maxInputTokens": 400000,
    "reservedCompletionTokens": 131072,
    "compactionTriggerTokens": 360000,
    "postCompactionTargetTokens": 280000,
